{"source":{"data":"@method=POST @endpoint=/ess/subscribe\nFeature: Subscription management for registry events\n\nThis API is exposed by ESS registry.\nIt allows SP systems to subscribe to registry events.\n\n    @smoke\n    Scenario: Successfully subscribe to events\n        Given SP system subscribes to ESS events\n        When A POST request to subscribe is sent\n        Then The response should be received\n        And The response status should be 200\n        And The response should have \"Content-Type\": \"application/json\" header\n        And The response should contain \"ack_status\" equal to \"ACK\"\n        And The response should be returned within 15000ms\n\n    @schema\n    Scenario: Subscribe response schema validation\n        Given A valid subscribe request is sent\n        When The response is received\n        Then The response should match the expected JSON schema","uri":"features/ess_subscribe.feature","mediaType":"text/x.cucumber.gherkin+plain"}}
{"gherkinDocument":{"feature":{"tags":[{"location":{"line":1,"column":1},"name":"@method=POST","id":"9311deee-57ec-42fd-851c-33eee1787711"},{"location":{"line":1,"column":14},"name":"@endpoint=/ess/subscribe","id":"2d7ce66f-4889-4038-b7e2-ddeb4486f4ac"}],"location":{"line":2,"column":1},"language":"en","keyword":"Feature","name":"Subscription management for registry events","description":"This API is exposed by ESS registry.\nIt allows SP systems to subscribe to registry events.","children":[{"scenario":{"id":"5d482a7f-7694-430a-a343-f897edd72fed","tags":[{"location":{"line":7,"column":5},"name":"@smoke","id":"25011c10-f8c2-4ef6-99e9-06653a3387cd"}],"location":{"line":8,"column":5},"keyword":"Scenario","name":"Successfully subscribe to events","description":"","steps":[{"id":"53193809-e0dc-46dc-85a5-289cb5fa6f96","location":{"line":9,"column":9},"keyword":"Given ","keywordType":"Context","text":"SP system subscribes to ESS events"},{"id":"3a71f59f-628c-4fd9-aead-394246920f7c","location":{"line":10,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to subscribe is sent"},{"id":"567e1839-71ee-484a-8752-99998dff0db8","location":{"line":11,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should be received"},{"id":"44cda14f-f6d7-4a58-9c53-5d517d90eb97","location":{"line":12,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response status should be 200"},{"id":"d4ebf111-c027-4cb3-ac2e-28590d825e68","location":{"line":13,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should have \"Content-Type\": \"application/json\" header"},{"id":"680fd8b9-6f83-43ed-b59c-51442a19c003","location":{"line":14,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should contain \"ack_status\" equal to \"ACK\""},{"id":"a5dfb143-008a-4b08-87f3-8a3044827137","location":{"line":15,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should be returned within 15000ms"}],"examples":[]}},{"scenario":{"id":"97d20e57-2ced-4ec4-bbdd-f2e4f1eb724a","tags":[{"location":{"line":17,"column":5},"name":"@schema","id":"f69e012c-e092-4753-83b3-63d3113e1a6a"}],"location":{"line":18,"column":5},"keyword":"Scenario","name":"Subscribe response schema validation","description":"","steps":[{"id":"fa5f2dcd-528c-4a02-bb52-97f7a5b405ad","location":{"line":19,"column":9},"keyword":"Given ","keywordType":"Context","text":"A valid subscribe request is sent"},{"id":"867b4002-060e-4afd-bce1-eb56643f86c2","location":{"line":20,"column":9},"keyword":"When ","keywordType":"Action","text":"The response is received"},{"id":"6d6b3d65-093a-49d8-b57b-680791e9844c","location":{"line":21,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should match the expected JSON schema"}],"examples":[]}}]},"comments":[],"uri":"features/ess_subscribe.feature"}}
