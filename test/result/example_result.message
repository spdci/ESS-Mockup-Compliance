a"}],"location":{"line":17,"column":5},"keyword":"Scenario","name":"Notification with invalid payload","description":"","steps":[{"id":"fff55463-598d-49c3-b85e-031dfac79765","location":{"line":18,"column":9},"keyword":"Given ","keywordType":"Context","text":"ESS receives malformed notification"},{"id":"71d188c2-1baa-45c3-9577-26e4ab8312d4","location":{"line":19,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to notify is sent"},{"id":"41e58e95-ecfc-43d7-93c5-f5c068789c0c","location":{"line":20,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The system should handle it gracefully"}],"examples":[]}},{"scenario":{"id":"e0c654ef-e1e4-46ec-b8f2-5a6ad1b854af","tags":[{"location":{"line":22,"column":5},"name":"@schema","id":"cb40cb5b-da46-4213-b286-13db28b230bb"}],"location":{"line":23,"column":5},"keyword":"Scenario","name":"Notification schema validation","description":"","steps":[{"id":"30d71901-911a-4f53-b8a9-00af33a90bd6","location":{"line":24,"column":9},"keyword":"Given ","keywordType":"Context","text":"A valid notification request is sent"},{"id":"abc7d0aa-5c1f-4b4b-b5e6-ed4555087d69","location":{"line":25,"column":9},"keyword":"When ","keywordType":"Action","text":"The response is received"},{"id":"0a1947ad-84cd-42a9-a66d-353c8841123e","location":{"line":26,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should match the expected JSON schema"}],"examples":[]}}]},"comments":[],"uri":"features/ess_notify.feature"}}
