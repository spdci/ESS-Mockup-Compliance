on","text":"The on subscribe response should match the expected JSON schema"}],"examples":[]}},{"scenario":{"id":"20670199-cd80-4458-817e-a742001d6efc","tags":[{"location":{"line":16,"column":5},"name":"@negative","id":"e232f7ac-ecfb-438a-a65e-3f90baf33a7e"}],"location":{"line":17,"column":5},"keyword":"Scenario","name":"On-subscribe with malformed payload","description":"","steps":[{"id":"67514e99-920a-41a3-a9e6-85c571ff3714","location":{"line":18,"column":9},"keyword":"Given ","keywordType":"Context","text":"ESS receives invalid subscription callback"},{"id":"311d145e-cba4-47c8-87a0-d1510e192479","location":{"line":19,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to on subscribe is sent"},{"id":"b63418b1-e967-4181-8234-aa0f93602224","location":{"line":20,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should still be received"},{"id":"01b30cfb-5ac3-4d5d-b33d-49dd185c2870","location":{"line":21,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The system should handle invalid payload gracefully"}],"examples":[]}}]},"comments":[],"uri":"features/ess_on-subscribe.feature"}}
