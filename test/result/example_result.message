 sent"},{"id":"e34e842b-309b-4af8-90db-862412e0c970","location":{"line":30,"column":9},"keyword":"When ","keywordType":"Action","text":"The response is received"},{"id":"df92f9a8-eef6-48dc-89ea-0da806e828f9","location":{"line":31,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should match the expected JSON schema"}],"examples":[]}}]},"comments":[],"uri":"features/ess_search.feature"}}
