junction","text":"The response should include \"correlation_id\""},{"id":"03bd27ef-6d79-4417-a3ba-bbf5749abd0d","location":{"line":16,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should be returned within 15000ms"}],"examples":[]}},{"scenario":{"id":"03e426d6-7c1e-4268-9f01-f8e2146a5297","tags":[{"location":{"line":18,"column":5},"name":"@negative","id":"24a5db03-e6da-4ed3-ba6c-3298d19afbe0"}],"location":{"line":19,"column":5},"keyword":"Scenario","name":"On-search with malformed payload","description":"","steps":[{"id":"4154a9cb-a108-4cb1-a033-4f5df9de4fa9","location":{"line":20,"column":9},"keyword":"Given ","keywordType":"Context","text":"ESS receives invalid JSON payload"},{"id":"c2879e2a-6a7d-48d3-b2f4-4202785810fb","location":{"line":21,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to on-search is sent"},{"id":"975b7a1f-222f-4ca2-9acd-0867f0688a0c","location":{"line":22,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should still be handled gracefully"}],"examples":[]}},{"scenario":{"id":"53f84b5d-1d21-4754-9f9d-4c3dc0f72815","tags":[{"location":{"line":24,"column":5},"name":"@schema","id":"a39f414b-fd70-4d0b-aa13-15df359c0999"}],"location":{"line":25,"column":5},"keyword":"Scenario","name":"On-search response schema validation","description":"","steps":[{"id":"521ecc3b-3802-4fe0-99be-43fbd45c3fbf","location":{"line":26,"column":9},"keyword":"Given ","keywordType":"Context","text":"A valid on-search request is sent"},{"id":"3ce7cc13-8120-43fe-b11f-91e39af8ba02","location":{"line":27,"column":9},"keyword":"When ","keywordType":"Action","text":"The response is received"},{"id":"1f12c401-2da7-4385-872a-59ea05de14e3","location":{"line":28,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should match the expected JSON schema"}],"examples":[]}}]},"comments":[],"uri":"features/ess_on-search.feature"}}
