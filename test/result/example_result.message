":"The on status response should match the expected JSON schema"}],"examples":[]}},{"scenario":{"id":"2fec9442-a863-4952-ad8c-5ceacb184769","tags":[{"location":{"line":16,"column":5},"name":"@negative","id":"666d7294-73aa-4c36-bf1a-9d13bf71c737"}],"location":{"line":17,"column":5},"keyword":"Scenario","name":"On-status with invalid transaction state","description":"","steps":[{"id":"c81fe76d-b3d1-4c0b-b867-f9586cc136b4","location":{"line":18,"column":9},"keyword":"Given ","keywordType":"Context","text":"ESS receives invalid transaction status payload"},{"id":"8ae6f0ea-551a-407c-9c28-f4abcb775604","location":{"line":19,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to on status is sent"},{"id":"59ee0d9f-a86c-4334-9fcb-c377a031f53d","location":{"line":20,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should still be received"},{"id":"2fb9ace6-f1a9-42cb-9fb3-a53a3e1f83fa","location":{"line":21,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The system should handle invalid status gracefully"}],"examples":[]}}]},"comments":[],"uri":"features/ess_txn_on-status.feature"}}
