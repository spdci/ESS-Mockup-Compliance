{"source":{"data":"@method=POST @endpoint=/ess/sync/status\nFeature: Synchronous transaction status check from ESS\n\nThis API allows SP systems to synchronously retrieve the status of a transaction from ESS.\n\n    @smoke\n    Scenario: Successfully retrieve transaction status\n        Given System wants to retrieve transaction status synchronously\n        When A POST request to sync status is sent\n        Then The sync status response should be received\n        And The async search response should have status 200\n        And The transaction status should be \"completed\"\n        And The sync status response should be returned in a timely manner within 15000ms\n        And The sync status response should match the expected JSON schema\n\n    @negative\n    Scenario: Sync status with invalid transaction id\n        Given System sends invalid transaction id for status check\n        When A POST request to sync status is sent\n        Then The sync status response should be received\n        And The response should handle invalid transaction gracefully","uri":"features/ess_sync_txn_status.feature","mediaType":"text/x.cucumber.gherkin+plain"}}
{"gherkinDocument":{"feature":{"tags":[{"location":{"line":1,"column":1},"name":"@method=POST","id":"97a09770-2434-4c0c-a8a0-69afee83565a"},{"location":{"line":1,"column":14},"name":"@endpoint=/ess/sync/status","id":"9ab33cfd-3582-4d40-bcd6-219a952d8650"}],"location":{"line":2,"column":1},"language":"en","keyword":"Feature","name":"Synchronous transaction status check from ESS","description":"This API allows SP systems to synchronously retrieve the status of a transaction from ESS.","children":[{"scenario":{"id":"92aac93c-57ba-4ed5-950e-3ef4861c4877","tags":[{"location":{"line":6,"column":5},"name":"@smoke","id":"7cec5490-80d6-40ba-b6c2-ee8f99e93fae"}],"location":{"line":7,"column":5},"keyword":"Scenario","name":"Successfully retrieve transaction status","description":"","steps":[{"id":"40504a3b-1716-43f4-8722-ae696dd4fc17","location":{"line":8,"column":9},"keyword":"Given ","keywordType":"Context","text":"System wants to retrieve transaction status synchronously"},{"id":"faabc95f-de39-4a9c-999b-1dc4758a5e46","location":{"line":9,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to sync status is sent"},{"id":"b95ce33a-1265-4ad5-8095-e7bbcc70f6b0","location":{"line":10,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The sync status response should be received"},{"id":"6eed4a22-66e8-4416-a00f-793ee7f67608","location":{"line":11,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The async search response should have status 200"},{"id":"73ade152-a8f2-4d20-958e-6252bbfd51a0","location":{"line":12,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The transaction status should be \"completed\""},{"id":"b8044713-47db-4333-bd59-3b9e1a476c69","location":{"line":13,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The sync status response should be returned in a timely manner within 15000ms"},{"id":"3f56d85f-529c-470f-8e43-58828f8220c7","location":{"line":14,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The sync status response should match the expected JSON schema"}],"examples":[]}},{"scenario":{"id":"ecc6636e-86b6-4582-89b9-d1266fbbd994","tags":[{"location":{"line":16,"column":5},"name":"@negative","id":"3d27e9ad-1773-45cf-a798-096697650061"}],"location":{"line":17,"column":5},"keyword":"Scenario","name":"Sync status with invalid transaction id","description":"","steps":[{"id":"e7808d78-0bc5-4b7f-9381-785977d97b8b","location":{"line":18,"column":9},"keyword":"Given ","keywordType":"Context","text":"System sends invalid transaction id for status check"},{"id":"58f09900-ed02-47ab-9ea8-1f86e19a5a18","location":{"line":19,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to sync status is sent"},{"id":"1b09d3f8-8285-4e8b-8a12-40a452d2cf90","location":{"line":20,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The sync status response should be received"},{"id":"7bf5b0c8-6b4b-4544-9084-9c13abb793dd","location":{"line":21,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should handle invalid transaction gracefully"}],"examples":[]}}]},"comments":[],"uri":"features/ess_sync_txn_status.feature"}}
