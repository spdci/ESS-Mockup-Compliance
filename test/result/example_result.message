unsubscribe response should match the expected JSON schema"}],"examples":[]}},{"scenario":{"id":"131287b6-1699-46d0-a290-23c1776a4cf7","tags":[{"location":{"line":16,"column":5},"name":"@negative","id":"386a694c-9482-446b-a87f-b69e6442737b"}],"location":{"line":17,"column":5},"keyword":"Scenario","name":"On-unsubscribe with missing fields","description":"","steps":[{"id":"8b45c88a-ce48-4a9c-b49d-f0e3236fcd61","location":{"line":18,"column":9},"keyword":"Given ","keywordType":"Context","text":"ESS receives invalid unsubscribe callback"},{"id":"892c913d-ef9d-4f3b-9e05-f47bef396397","location":{"line":19,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to on unsubscribe is sent"},{"id":"7a950a64-76c0-4be6-8f53-179842de7cdc","location":{"line":20,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should still be received"},{"id":"686a2374-efa3-4239-9321-47ef0d33606b","location":{"line":21,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The system should handle invalid payload gracefully"}],"examples":[]}}]},"comments":[],"uri":"features/ess_on-unsubscribe.feature"}}
