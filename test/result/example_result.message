:"The txn_status should be \"completed\""},{"id":"5061b5b6-8acd-46c0-ad0d-eaafe4ccc4db","location":{"line":16,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should be returned within 15000ms"}],"examples":[]}},{"scenario":{"id":"13d0ad17-413a-48e2-93c0-a39b756e4d29","tags":[{"location":{"line":18,"column":5},"name":"@negative","id":"f434c110-4311-43de-8d45-91d8f43d70da"}],"location":{"line":19,"column":5},"keyword":"Scenario","name":"Transaction status for invalid transaction_id","description":"","steps":[{"id":"1c7c2c29-d468-4605-a07b-5e5757b3f6fb","location":{"line":20,"column":9},"keyword":"Given ","keywordType":"Context","text":"SP system sends invalid transaction_id"},{"id":"f1f212a1-3347-4bd6-b89e-b77f31575cac","location":{"line":21,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to transaction status is sent"},{"id":"dc4935f4-689f-4934-8c16-d3dcde8ac48b","location":{"line":22,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should still be received"}],"examples":[]}},{"scenario":{"id":"2a6b427b-ea35-4628-887b-7a92c5340395","tags":[{"location":{"line":24,"column":5},"name":"@schema","id":"851a7464-66c7-480c-a5d0-310caf5e5eb7"}],"location":{"line":25,"column":5},"keyword":"Scenario","name":"Transaction status schema validation","description":"","steps":[{"id":"a14310b4-8160-43f9-8dc8-2ec564e8048e","location":{"line":26,"column":9},"keyword":"Given ","keywordType":"Context","text":"A valid transaction status request is sent"},{"id":"1c7d1ba6-a911-4c76-8aaf-bf338a42cb2d","location":{"line":27,"column":9},"keyword":"When ","keywordType":"Action","text":"The response is received"},{"id":"587be18c-2448-453a-8bb7-bfd71013f5bc","location":{"line":28,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should match the expected JSON schema"}],"examples":[]}}]},"comments":[],"uri":"features/ess_txn_status.feature"}}
