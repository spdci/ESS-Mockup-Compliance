esponse should include at least one \"reg_record\""},{"id":"5d4d6974-d1b4-464c-a19b-95a0c7c19d57","location":{"line":16,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The response should be returned within 15000ms"}],"examples":[]}},{"scenario":{"id":"99ef581f-b846-4e3f-96cd-73fc7aeab86c","tags":[{"location":{"line":18,"column":5},"name":"@smoke","id":"f44620f1-bc37-4cbf-b752-8bf7e0c598e3"}],"location":{"line":19,"column":5},"keyword":"Scenario","name":"Sync search by valid UIN returns member data","description":"","steps":[{"id":"4bcf7fcc-70c8-4461-b68b-d0113fc1264c","location":{"line":20,"column":9},"keyword":"Given ","keywordType":"Context","text":"SP system searches using UIN \"42343545654\""},{"id":"1fde2f43-8125-4e23-8de0-b24c30598f78","location":{"line":21,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to sync search is sent"},{"id":"4ad54da2-a9c8-4300-a75f-9e8de6467936","location":{"line":22,"column":9},"keyword":"Then ","keywordType":"Outcome","text":"The response should contain member \"Alice Smith\""},{"id":"994ed089-de4d-4110-875d-2ffa0f7975a4","location":{"line":23,"column":9},"keyword":"And ","keywordType":"Conjunction","text":"The employment_status should be \"employed\""}],"examples":[]}},{"scenario":{"id":"828aaf1f-185c-45b5-8add-8140dc03622f","tags":[{"location":{"line":25,"column":5},"name":"@negative","id":"5da4af9f-4307-43fd-86b7-c0215379c1f7"}],"location":{"line":26,"column":5},"keyword":"Scenario","name":"Sync search with unknown UIN","description":"","steps":[{"id":"23851110-51e5-4723-b930-6cf557c3e202","location":{"line":27,"column":9},"keyword":"Given ","keywordType":"Context","text":"SP system searches using invalid UIN \"00000000000\""},{"id":"51784dd2-e2fc-4d02-8a3a-ebe84ba15baf","location":{"line":28,"column":9},"keyword":"When ","keywordType":"Action","text":"A POST request to sync search is sent"},{"id":"9c5335ec-d96b-4c4c-80c1-cd1f7178d8be","location":{"line":29,"column":9},"keyword":"Th